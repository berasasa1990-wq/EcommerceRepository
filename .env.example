# ==========================================
# .env.example - Kopiraj u .env i popuni
# ==========================================

# ProtonMail SMTP (Settings → Proton Mail → IMAP/SMTP → SMTP token)
EMAIL_HOST=smtp.protonmail.ch
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=narudzbe@opremazaribolov.ba
EMAIL_APP_PASSWORD=ovdje_unesite_smtp_token
DEFAULT_FROM_EMAIL=narudzbe@opremazaribolov.ba
ORDER_NOTIFICATION_EMAIL=narudzbe@opremazaribolov.ba
STORE_EMAIL=narudzbe@opremazaribolov.ba

# Marketing email — grupe po 50, pauza 4s između grupa
# MARKETING_EMAIL_BATCH_SIZE=50
# MARKETING_EMAIL_GROUP_PAUSE=4

# ==========================================
# RENDER PRODUCTION SETUP
# ==========================================

# Generiši novi: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=generisite_jedan_jak_secret_key_ovdje

DEBUG=false

# Na Renderu stavi samo domene (bez https:// !)
ALLOWED_HOSTS=tvoja-aplikacija.onrender.com,*.onrender.com

SITE_URL=https://tvoja-aplikacija.onrender.com

# Render automatski dodaje DATABASE_URL kada povežeš PostgreSQL service
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Disk za media (proizvodi, slike, logo...)
# 1. Na Renderu kreiraj Disk sa Mount Path: /var/data
# 2. Ovdje stavi isti path:
RENDER_DISK_PATH=/var/data

# CSRF trusted origins (obavezno!)
# Render:
CSRF_TRUSTED_ORIGINS=https://tvoja-aplikacija.onrender.com,https://*.onrender.com
# Lokalno:
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:8000

# ==========================================
# SYNC (Loyalty program na Renderu)
# ==========================================
SYNC_REMOTE_URL=https://loyaltyprogram-jsg5.onrender.com
SYNC_API_KEY=kopiraj_isti_kljuc_sa_loyalty_servisa

# ==========================================
# OLX.ba / Pik (isti API)
# ==========================================
OLX_API_TOKEN=token_iz_olx_profila
OLX_CITY_ID=77
OLX_COUNTRY_ID=49
OLX_DEFAULT_CATEGORY_ID=1260

# ==========================================
# ODOO IMPORT
# ==========================================
ODOO_URL=https://carpologijabhnova.odoo.com
ODOO_DB=carpologijabhnova
ODOO_USERNAME=carpologijabh@gmail.com
ODOO_API_KEY=e9bfae5513049fe006829e616f636ad86e15ce6e

# ==========================================
# Cloudflare Turnstile (opcionalno)
# ==========================================
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ==========================================
# Sajt u pripremi (lozinka za pristup prije lansiranja)
# ==========================================
SITE_PREP_ENABLED=true
SITE_PREP_PASSWORD=postavite_jaku_lozinku_ovdje

# ==========================================
# Meta (Facebook / Instagram) Pixel + Conversions API
# ==========================================
META_PIXEL_ID=27729172960012475
META_ACCESS_TOKEN=generisite_u_meta_events_manageru

